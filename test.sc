int main() {
    int score = 85;
if (score >= 90) {
    printf("Grade: A\n");
} else if (score >= 80) {
    printf("Grade: B\n");
} else if (score >= 70) {
    printf("Grade: C\n");
} else {
    printf("Grade: F\n");
}

int n = 17;
if (n % 2 == 0) {
    printf("%d is even\n", n);
} else {
    printf("%d is odd\n", n);
}
}
